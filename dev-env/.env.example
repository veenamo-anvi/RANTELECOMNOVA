# --- InfluxDB (self-init via DOCKER_INFLUXDB_INIT_*) ---
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme-admin-pass
INFLUXDB_ORG=telecom
INFLUXDB_BUCKET=telecom_metrics
INFLUXDB_TOKEN=changeme-influx-token

# --- Grafana ---
GRAFANA_PASSWORD=changeme-grafana-pass

# --- Orchestrator LLM backends (Appendix G) ---
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# Optional Claude-CLI backend: set CLAUDE_CLI_PATH to activate
# CLAUDE_CLI_PATH=/usr/bin/claude
ANTHROPIC_MODEL_NAME=sonnet

# --- Claude-CLI mount (host ~/.claude -> container /root/.claude) ---
# On Windows set USERPROFILE; CLAUDE_HOME overrides the mount source if set.
# USERPROFILE=C:\Users\you
# CLAUDE_HOME=
