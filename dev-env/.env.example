# --- InfluxDB (self-init via DOCKER_INFLUXDB_INIT_*) ---
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme-admin-pass
INFLUXDB_ORG=telecom
INFLUXDB_BUCKET=telecom_metrics
INFLUXDB_TOKEN=changeme-influx-token

# --- Grafana ---
GRAFANA_PASSWORD=changeme-grafana-pass

# Optional: change if host port 8086 is already in use (host port only; internal stays 8086)
# INFLUX_HOST_PORT=8086

# --- Orchestrator LLM backends ---
# Backend selection (first match wins): ANTHROPIC_API_KEY -> CLAUDE_CLI_PATH -> Gemini.
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Anthropic API backend (official SDK, real tool-calling). Set the key to activate.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# Optional Claude-CLI backend (text-only): set CLAUDE_CLI_PATH to activate
# CLAUDE_CLI_PATH=/usr/bin/claude
ANTHROPIC_MODEL_NAME=sonnet

# --- Claude-CLI mount (host ~/.claude -> container /root/.claude) ---
# On Windows set USERPROFILE; CLAUDE_HOME overrides the mount source if set.
# USERPROFILE=C:\Users\you
# CLAUDE_HOME=
