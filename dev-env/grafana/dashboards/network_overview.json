{
  "uid": "net-overview",
  "title": "Malleswaram Network Overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "tags": [
    "telecom"
  ],
  "timezone": "browser",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Connected UEs",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-telecom"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-telecom"
          },
          "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"connected_ues\")\n  |> last()\n  |> group()\n  |> sum()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "title": "Avg SINR (dB)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-telecom"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-telecom"
          },
          "query": "from(bucket: \"telecom_metrics\") |> range(start: -5m) |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"sinr_db\") |> mean() |> group() |> mean()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "none"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Total Power (kW)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-telecom"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-telecom"
          },
          "query": "from(bucket: \"telecom_metrics\") |> range(start: -5m) |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"power_w\") |> last() |> group() |> sum() |> map(fn: (r) => ({r with _value: r._value / 1000.0}))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "kwatt"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Overloaded Cells (PRB>85%)",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-telecom"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-telecom"
          },
          "query": "from(bucket: \"telecom_metrics\") |> range(start: -5m) |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"prb_dl_pct\") |> last() |> filter(fn: (r) => r._value > 85.0) |> group() |> count()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "Connected UEs over time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-telecom"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-telecom"
          },
          "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"connected_ues\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 6,
      "title": "Avg DL Throughput (Mbps)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-telecom"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-telecom"
          },
          "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"dl_throughput_mbps\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ]
}
